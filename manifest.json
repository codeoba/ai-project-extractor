{
  "manifest_version": 3,
  "name": "AI Project Extractor",
  "version": "1.1",
  "description": "Extracts, edits, diffs, syncs locally, and pushes code projects from AI chats to GitHub.",
  "permissions": [
    "downloads",
    "activeTab",
    "storage"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://gemini.google.com/*",
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://chat.deepseek.com/*",
        "https://claude.ai/*"
      ],
      "css": ["content.css"],
      "js": ["libs/jszip.min.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Project Extractor"
  },
  "background": {
    "service_worker": "background.js"
  }
}
